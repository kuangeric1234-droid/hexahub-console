# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://hexa:changeme@localhost:5432/hexa_hub

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth — legacy single-password ─────────────────────────────────────────────
SECRET_KEY=changeme-generate-a-real-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
API_PASSWORD=changeme             # portal login password → POST /api/v1/auth/token

# ── Auth — JWT (multi-user) ────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=changeme-generate-a-real-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Webhooks ───────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=changeme-webhook-secret  # X-Webhook-Secret header value

# ── LLM providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
QWEN_API_KEY=       # optional — for Chinese-platform agents
DEEPSEEK_API_KEY=   # optional — for Chinese-platform agents

# ── Storage (MinIO / S3) ───────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=hexa-hub-assets

# ── Platform publishing ────────────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
META_ACCESS_TOKEN=
META_IG_USER_ID=
WORDPRESS_URL=
WORDPRESS_APP_PASSWORD=

# ── Webhook for XHS / WeChat manual publishing ────────────────────────────────
WEBHOOK_URL=

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false
DOCS_ENABLED=true
