# ── Database ───────────────────────────────────────────────────────────────────
# asyncpg driver used by the FastAPI app; Alembic swaps to psycopg2 at runtime
DATABASE_URL=postgresql+asyncpg://hexa:changeme@localhost:5432/hexa_hub

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-real-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 h

# ── LLM providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
QWEN_API_KEY=       # optional — for Chinese-platform agents
DEEPSEEK_API_KEY=   # optional — for Chinese-platform agents

# ── Storage (MinIO / S3) ───────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=hexa-hub-assets

# ── Platform publishing ────────────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=             # urn:li:person:{your-id}
META_ACCESS_TOKEN=
META_IG_USER_ID=
WORDPRESS_URL=                   # https://blog.hexahub.com.au
WORDPRESS_APP_PASSWORD=

# ── Manual publishing webhook (XHS / WeChat) ──────────────────────────────────
# POST target for publishing packages — Slack webhook, n8n, Make.com, etc.
WEBHOOK_URL=

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false
